rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bloqueio total por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper para verificar se o documento pertence ao usuário
    // O checking resource.data.userId == request.auth.uid é o que permite o 'list' com query filtrada
    function isOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Regras unificadas para todas as coleções financeiras
    match /{collection}/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
