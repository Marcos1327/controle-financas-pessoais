rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bloqueio total por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper para verificar se o documento pertence ao usuário
    // Usamos has('userId') para evitar erros se o campo não existir em docs antigos
    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    // Coleções permitidas
    match /categorias/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
    }
    
    match /dividas_fixas/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
    }
    
    match /dividas_parceladas/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
    }
    
    match /compras_avulsas/{id} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(resource.data);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);
    }
  }
}
