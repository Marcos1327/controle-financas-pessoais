rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bloqueio total por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Função auxiliar para verificar se está autenticado (mesmo que anonimamente)
    function isSignedIn() {
      return request.auth != null;
    }

    // Regras para as coleções: Só pode ler/escrever se o userId do documento bater com o auth.uid
    
    match /categorias/{id} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }
    
    match /dividas_fixas/{id} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }
    
    match /dividas_parceladas/{id} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }
    
    match /compras_avulsas/{id} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.userId == request.auth.uid
      ) && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      );
    }
  }
}
